# All env vars active ONLY when you cd into this directory
export KUBECONFIG="$(pwd)/.kube/config"
export COLIMA_PROFILE="k8s-temporal"
export TEMPORAL_ADDRESS="localhost:7233"
export TEMPORAL_NAMESPACE="default"
export OPENAI_API_KEY=""

# Optional: namespace shortcut
alias k='kubectl'
alias kns='kubens'

echo "✓ k8s-temporal env active | KUBECONFIG=$(pwd)/.kube/config"
